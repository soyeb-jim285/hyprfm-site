---
// TODO(jim): edit any of the feature titles/descriptions below to your voice.
// I pulled these from the README's feature list — they're your words already,
// just paraphrased for the card format.
const features = [
  {
    title: 'Three views',
    body: 'Grid, detailed columns, and Miller columns with live previews. Switch with Ctrl+1/2/3 without reaching for a mouse.',
    icon: 'layout-grid',
  },
  {
    title: 'Quick preview',
    body: 'Space bar opens a full-screen overlay for images, video, PDFs, text, and audio, with metadata on the side.',
    icon: 'eye',
  },
  {
    title: 'Tabs and split pane',
    body: 'Per-tab history and a side-by-side pane for working in two directories at once. Drag between them.',
    icon: 'columns',
  },
  {
    title: 'fd-powered search',
    body: 'Full-path search with glob and fixed-string matching, powered by fd. Falls back to a Qt iterator if fd is missing.',
    icon: 'search',
  },
  {
    title: 'UDisks2 devices',
    body: 'Mount and unmount removable drives from the sidebar, directly over DBus — no shell-out to udisksctl.',
    icon: 'hard-drive',
  },
  {
    title: 'TOML themes',
    body: 'Live-reloaded TOML themes with Catppuccin Mocha and Latte out of the box, plus configurable radius and fonts.',
    icon: 'palette',
  },
];

const icons: Record<string, string> = {
  'layout-grid': '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
  'eye': '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
  'columns': '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M12 3v18"/>',
  'search': '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  'hard-drive': '<line x1="22" x2="2" y1="12" y2="12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" x2="6.01" y1="16" y2="16"/><line x1="10" x2="10.01" y1="16" y2="16"/>',
  'palette': '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
};
---

<section id="features" class="section relative">
  <div class="container-narrow">
    <div class="max-w-2xl mb-16 reveal">
      <span class="text-sm font-medium text-mauve tracking-wider uppercase">Features</span>
      <h2 class="mt-3 text-hero font-bold">Built for power users who live in the terminal.</h2>
      <p class="mt-4 text-subtext1 text-lg">
        {/* TODO(jim): rewrite this paragraph in your own words. */}
        Keyboard-first navigation, async file operations, rich previews, and a
        theme system that respects your Wayland desktop. No bloat, no telemetry.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature, i) => (
        <div class:list={['card reveal', `reveal-delay-${(i % 6) + 1}`]}>
          <div class="mb-4 inline-flex items-center justify-center size-11 rounded-xl bg-surface0/80 text-mauve">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[feature.icon]} />
          </div>
          <h3 class="font-semibold text-lg mb-1.5">{feature.title}</h3>
          <p class="text-subtext0 text-sm leading-relaxed">{feature.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
