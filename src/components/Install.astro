---
import { getLatestVersion } from "../lib/version";

const version = await getLatestVersion();
const tabs = [
  {
    id: 'flatpak',
    label: 'Flatpak',
    blurb: 'Signed repository at hyprfm.soyebjim.me. Updates via flatpak update. Requires the Flathub remote at the same (--user) scope so the KDE runtime can be pulled.',
    code: `# Flathub must exist at the --user scope to provide org.kde.Platform
flatpak remote-add --user --if-not-exists \\
    flathub https://dl.flathub.org/repo/flathub.flatpakrepo
flatpak remote-add --user --if-not-exists \\
    hyprfm https://flatpak.hyprfm.soyebjim.me/hyprfm.flatpakrepo
flatpak install --user hyprfm io.github.soyeb_jim285.HyprFM`,
  },
  {
    id: 'aur',
    label: 'Arch (AUR)',
    blurb: 'Built from latest main, installs to /usr/bin/hyprfm.',
    code: `yay -S hyprfm-git`,
  },
  {
    id: 'appimage',
    label: 'AppImage',
    blurb: 'Fully self-contained, no system Qt needed.',
    code: `wget https://github.com/soyeb-jim285/hyprfm/releases/latest/download/HyprFM-${version}-x86_64.AppImage
chmod +x HyprFM-*.AppImage
./HyprFM-*.AppImage`,
  },
  {
    id: 'source',
    label: 'Source',
    blurb: 'Requires Qt6, CMake, Ninja. Submodules must be fetched.',
    code: `git clone --recursive https://github.com/soyeb-jim285/hyprfm.git
cd hyprfm
cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release
cmake --build build --parallel
./build/src/hyprfm`,
  },
];
---

<section id="install" class="section relative">
  <div class="container-narrow">
    <div class="max-w-2xl mb-12 reveal">
      <span class="text-sm font-medium text-mauve tracking-wider uppercase">Install</span>
      <h2 class="mt-3 text-hero font-bold">Pick your distribution.</h2>
      <p class="mt-4 text-subtext1 text-lg">
        Four supported install paths. Flatpak is the recommended option for
        non-Arch systems — it ships everything HyprFM needs in a single
        sandboxed package.
      </p>
    </div>

    <div class="panel overflow-hidden reveal" data-install-tabs>
      {/* Tab headers — styled as a horizontal pill row */}
      <div class="flex flex-wrap gap-1 p-2 border-b border-surface0/80 bg-mantle/30" role="tablist" aria-label="Install methods">
        {tabs.map((tab, i) => (
          <button
            type="button"
            role="tab"
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              'data-[active=true]:bg-surface1 data-[active=true]:text-text',
              'text-subtext0 hover:text-text hover:bg-surface0/60',
            ]}
            data-tab={tab.id}
            data-active={i === 0 ? 'true' : 'false'}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`tab-${tab.id}`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      {/* Panels */}
      <div class="p-6 md:p-8">
        {tabs.map((tab, i) => (
          <div
            id={`tab-${tab.id}`}
            role="tabpanel"
            data-panel={tab.id}
            hidden={i !== 0}
          >
            <p class="text-subtext1 mb-4 text-sm">{tab.blurb}</p>
            <div class="code-block">
              <button
                type="button"
                class="absolute top-3 right-3 inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md bg-surface0/80 border border-surface1 text-xs text-subtext1 hover:bg-surface1 hover:text-text transition-colors"
                data-copy-target={`code-${tab.id}`}
                aria-label={`Copy ${tab.label} install command`}
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                  <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                </svg>
                <span data-copy-label>Copy</span>
              </button>
              <pre id={`code-${tab.id}`} class="text-text/90 pr-20"><code>{tab.code}</code></pre>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Tab switching with fade-slide animation
  document.querySelectorAll('[data-install-tabs]').forEach((root) => {
    const buttons = root.querySelectorAll('[data-tab]');
    const panels = root.querySelectorAll('[data-panel]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-tab');
        buttons.forEach((b) => {
          const active = b === btn;
          b.setAttribute('data-active', active ? 'true' : 'false');
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach((p) => {
          const show = p.getAttribute('data-panel') === id;
          p.hidden = !show;
          if (show) {
            p.classList.remove('tab-enter');
            // Force reflow so the animation restarts
            void p.offsetWidth;
            p.classList.add('tab-enter');
          }
        });
      });
    });
  });

  // Copy-to-clipboard buttons
  document.querySelectorAll('[data-copy-target]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-copy-target');
      const target = document.getElementById(targetId);
      if (!target) return;
      try {
        await navigator.clipboard.writeText(target.textContent.trim());
        const label = btn.querySelector('[data-copy-label]');
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = original; }, 1600);
        }
      } catch (err) {
        console.error('Copy failed:', err);
      }
    });
  });
</script>
