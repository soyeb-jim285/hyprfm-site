---
import { getLatestVersion } from "../lib/version";

const version = await getLatestVersion();
const tagline = "A fast, keyboard-driven file manager for Hyprland and other Wayland compositors.";
---

<section class="relative overflow-hidden">
  {/* Decorative gradient orbs — sit behind the content, absolutely
      positioned, pointer-events-none so they never interfere with clicks. */}
  <div aria-hidden="true" class="absolute inset-0 overflow-hidden">
    <div class="orb animate-float-slow" style="width: 520px; height: 520px; background: #cba6f7; top: -120px; left: -160px;"></div>
    <div class="orb animate-float-slow" style="width: 640px; height: 640px; background: #89b4fa; top: 20%; right: -220px; animation-delay: -4s;"></div>
    <div class="orb animate-float-slow" style="width: 400px; height: 400px; background: #f5c2e7; bottom: -140px; left: 30%; animation-delay: -8s;"></div>
    <div class="absolute inset-0 dot-grid"></div>
  </div>

  <div class="relative container-narrow pt-28 pb-24 md:pt-40 md:pb-32">
    <nav class="flex items-center justify-between mb-20 md:mb-28 reveal">
      <a href="/" class="flex items-center gap-3 group" aria-label="HyprFM home">
        <img src="/hyprfm.svg" alt="" width="32" height="32" class="transition-transform group-hover:scale-110" />
        <span class="font-semibold text-lg tracking-tight">HyprFM</span>
      </a>
      <div class="flex items-center gap-2">
        <a href="#install" class="btn-secondary text-sm !px-4 !py-2">Install</a>
        <a
          href="https://github.com/soyeb-jim285/hyprfm"
          class="btn-secondary text-sm !px-4 !py-2"
          rel="noopener"
          aria-label="Source on GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.77.42-1.3.76-1.6-2.67-.3-5.47-1.34-5.47-5.94 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.17 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.41 1.02.01 2.04.14 3 .41 2.28-1.55 3.29-1.23 3.29-1.23.66 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.93.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </div>
    </nav>

    <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-center">
      <div class="md:col-span-6 lg:col-span-7">
        <div class="reveal">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface0/60 border border-surface1 text-xs font-medium text-subtext1 mb-6">
            <span class="size-1.5 rounded-full bg-green animate-pulse"></span>
            {version} available
          </div>
        </div>

        <h1 class="text-display font-bold mb-6 reveal reveal-delay-1">
          <span class="text-gradient">HyprFM</span>
        </h1>

        <p class="text-hero text-subtext1 mb-10 max-w-2xl reveal reveal-delay-2">
          {tagline}
        </p>

        <div class="flex flex-wrap gap-3 reveal reveal-delay-3">
          <a href="#install" class="btn-primary">
            Get HyprFM
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 5v14M19 12l-7 7-7-7"/>
            </svg>
          </a>
          <a
            href="https://github.com/soyeb-jim285/hyprfm"
            class="btn-secondary"
            rel="noopener"
          >
            Source code
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>
        </div>

        <ul class="mt-12 flex flex-wrap gap-x-6 gap-y-2 text-sm text-subtext0 reveal reveal-delay-4">
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-green"><polyline points="20 6 9 17 4 12"/></svg>
            Wayland-native
          </li>
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-green"><polyline points="20 6 9 17 4 12"/></svg>
            Keyboard-first
          </li>
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-green"><polyline points="20 6 9 17 4 12"/></svg>
            MIT licensed
          </li>
        </ul>
      </div>

      <div class="md:col-span-6 lg:col-span-5 reveal reveal-delay-3">
        <div class="relative">
          {/* Subtle glow behind the hero image */}
          <div class="absolute -inset-6 rounded-3xl bg-gradient-to-br from-mauve/30 via-blue/20 to-transparent blur-2xl"></div>
          <div class="relative panel overflow-hidden shadow-2xl">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-surface0/80 bg-mantle/40">
              <span class="size-3 rounded-full bg-red/70"></span>
              <span class="size-3 rounded-full bg-yellow/70"></span>
              <span class="size-3 rounded-full bg-green/70"></span>
              <span class="ml-3 text-xs text-overlay1 font-mono">~/Pictures — hyprfm</span>
            </div>
            <img
              src="/screenshots/hero.svg"
              alt="HyprFM grid view showing image thumbnails and a sidebar with bookmarks"
              class="w-full h-auto aspect-[16/10] object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
